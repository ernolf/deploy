def usage() -> None:
    print(f"""\
deploy — personal package manager for gist-based mini-packages
         OS: {OS_CTX['OS']} {OS_CTX['OS_VERSION']} ({OS_CTX['ARCH']}) | pkg: {OS_CTX['PKG_MANAGER']}

Usage:
  deploy me                         Install deploy itself (run once as root)
  deploy inspect <ref>              Show package info and deploy.sh without installing
  deploy install <ref> [--yes]      Clone and install a package
  deploy remove  <name>             Remove package (keeps clone and config)
  deploy purge   <name>             Remove package, config, build artifacts, and clone
  deploy update  me                 Update deploy itself from the repository
  deploy update  [<name>|--all]     git pull + re-run deploy.sh update
  deploy status  [<name>]           Show status (all packages if omitted)
  deploy log     <name>             Show recent log (last 60 lines)
  deploy list                       List all installed packages

  deploy bundle  <bundle.json> --continue-on-error   Report failures but install remaining packages
  deploy platforms                  List supported package source platforms

  <ref> is a short Gist ID, or a full URL for any other platform.
  Run 'deploy platforms' to see all supported formats.
  Use '--yes' to skip the confirmation prompt (for scripts/automation).

Options:
  -h, --help    Show this help

Registry:  /var/lib/deploy/registry.json
Packages:  /var/lib/deploy/packages/
Logs:      /var/log/deploy/
OS lib:    /var/lib/deploy/lib/os-lib.sh
Repo:      {DEPLOY_REPO_URL}""")


# == Entry point ===============================================================

def main() -> None:
    args = sys.argv[1:]
    cmd  = args[0] if args else ""
    arg2 = args[1] if len(args) > 1 else ""

    # Self-installation commands do not require a working environment.
    if cmd in ("-h", "--help", "help", ""):
        usage()
        return
    if cmd == "me":
        cmd_me()
        return
    if cmd == "update" and arg2 == "me":
        cmd_update_me()
        return

    # All other commands: warn if deploy hasn't been installed via 'deploy me'.
    _check_environment()

    if   cmd == "inspect": cmd_inspect(arg2)
    elif cmd == "install": cmd_install(arg2, yes="--yes" in args)
    elif cmd == "remove":  cmd_remove(arg2)
    elif cmd == "purge":   cmd_purge(arg2)
    elif cmd == "update":  cmd_update(arg2 or "--all")
    elif cmd == "status":  cmd_status(arg2)
    elif cmd == "log":     cmd_log(arg2)
    elif cmd == "list":    cmd_list()
    elif cmd == "bundle":    cmd_bundle(arg2, continue_on_error="--continue-on-error" in args)
    elif cmd == "platforms": cmd_platforms()
    else:
        die(f"Unknown command: '{cmd}'. Run 'deploy --help'.")


if __name__ == "__main__":
    main()

# == Command: bundle ===========================================================

def cmd_bundle(bundle_file: str, continue_on_error: bool = False) -> None:
    if not bundle_file:
        die("Usage: deploy bundle <bundle.json> [--continue-on-error]")

    bundle_path = Path(bundle_file)
    if not bundle_path.is_file():
        die(f"Bundle file not found: {bundle_file}")

    require_root(f"bundle {bundle_file}")

    with open(bundle_path) as f:
        bundle = json.load(f)

    description = bundle.get("description", "unnamed bundle")
    # Accept "origin" and legacy keys "source" / "gist"
    refs = [p.get("origin") or p.get("source") or p.get("gist")
            for p in bundle.get("packages", [])
            if  p.get("origin") or p.get("source") or p.get("gist")]

    if not refs:
        die("No packages found in bundle file.")

    info(f"Bundle: {description}")
    info(f"Installing {len(refs)} package(s) on {OS_CTX['OS']}/{OS_CTX['PKG_MANAGER']} ...")
    if continue_on_error:
        info("--continue-on-error: failures will be reported but will not stop installation.")

    failed = []
    total = len(refs)
    for idx, ref in enumerate(refs, 1):
        print()
        print(f"── [{idx}/{total}] {ref} {'─' * max(0, 60 - len(ref))}──")
        try:
            cmd_install(ref, yes=True, skip_installed=True, quiet_clone=True)
        except SystemExit as e:
            if e.code != 0:
                warn(f"Failed to install: {ref}")
                if not continue_on_error:
                    die(f"Bundle aborted after failure. Pass --continue-on-error to proceed past failures.")
                failed.append(ref)

    print()
    if not failed:
        info("Bundle installation complete. All packages installed.")
    else:
        warn(f"Bundle finished with {len(failed)} failure(s):")
        for ref in failed:
            warn(f"  - {ref}")
        sys.exit(1)


